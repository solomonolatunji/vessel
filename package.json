{
  "name": "vessl",
  "private": true,
  "version": "0.1.0",
  "description": "Self-hosted PaaS — turn any bare-metal VPS into your own private Vercel & Railway.",
  "license": "MIT",
  "workspaces": [
    "dashboard",
    "web",
    "docs"
  ],
  "scripts": {
    "dev:dashboard": "npm --workspace=dashboard run dev",
    "dev:web": "npm --workspace=web run dev",
    "dev:docs": "npm --workspace=docs run dev",
    "build:dashboard": "npm --workspace=dashboard run build",
    "build:web": "npm --workspace=web run build",
    "build:all": "npm run build:dashboard && npm run build:web",
    "build:docs": "npm --workspace=docs run build",
    "deploy:web": "npm --workspace=web run deploy",
    "deploy:docs": "npm --workspace=docs run deploy",
    "deploy:all": "npm run deploy:web && npm run deploy:docs",
    "test:dashboard": "npm --workspace=dashboard run test",
    "typecheck": "npm --workspace=dashboard run generate-routes && tsc -b dashboard",
    "format": "biome check .",
    "format:fix": "biome check --write .",
    "lint": "biome check . && gofmt -l ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "concurrently": "^10.0.3",
    "wrangler": "^4.110.0"
  }
}
