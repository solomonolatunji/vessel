---
import { Icon } from 'astro-icon/components';
---

<footer class="mt-24 border-t border-border bg-background/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 py-12 flex flex-col md:flex-row items-center justify-between gap-8">

    <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-2 text-center sm:text-left">
      <span class="size-6 rounded-md bg-primary flex items-center justify-center text-white text-xs font-black">V</span>
      <span class="text-sm text-muted-foreground">© 2026 Codedock. Open-source &amp; free forever.</span>
    </div>

    <div class="flex flex-col sm:flex-row flex-wrap justify-center items-center gap-4 sm:gap-2 text-sm text-muted-foreground">
      <div class="flex flex-wrap justify-center items-center gap-1 sm:gap-2">
        <a href="/philosophy" class="px-3 py-2 rounded-md hover:text-foreground hover:bg-surface transition-colors">Philosophy</a>
        <a href="/pricing" class="px-3 py-2 rounded-md hover:text-foreground hover:bg-surface transition-colors">Pricing</a>
        <a href="/changelog" class="px-3 py-2 rounded-md hover:text-foreground hover:bg-surface transition-colors">Changelog</a>
        <a href="https://docs.codedock.run" target="_blank" class="px-3 py-2 rounded-md hover:text-foreground hover:bg-surface transition-colors">Docs</a>
      </div>

      <!-- Icon-only social links -->
      <div class="flex items-center gap-2 sm:gap-1 sm:ml-2 sm:pl-4 sm:border-l border-border pt-2 sm:pt-0 border-t sm:border-t-0 w-full sm:w-auto justify-center">
        <!-- GitHub -->
        <a href="https://github.com/techxteam/codedock" target="_blank" aria-label="GitHub"
          class="p-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-surface transition-colors">
          <Icon name="simple-icons:github" class="size-4" />
        </a>
        <!-- X (Twitter) -->
        <a href="https://x.com/codedockdotdev" target="_blank" aria-label="X / Twitter"
          class="p-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-surface transition-colors">
          <Icon name="simple-icons:x" class="size-4" />
        </a>
        <!-- Discord -->
        <a href="https://discord.gg/codedock" target="_blank" aria-label="Discord"
          class="p-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-surface transition-colors">
          <Icon name="simple-icons:discord" class="size-4" />
        </a>
      </div>
    </div>

  </div>
</footer>
