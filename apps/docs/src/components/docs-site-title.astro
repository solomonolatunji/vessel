---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="docs-site-title">
  <span class="docs-site-title__mark">
    <img src="/favicon.svg" alt="" />
  </span>
  <span translate="no">Codedock Docs</span>
</a>

<style>
  @layer starlight.components {
    .docs-site-title {
      display: inline-flex;
      min-width: 0;
      align-items: center;
      gap: 0.75rem;
      color: var(--sl-color-white);
      font-family: var(--sl-font);
      font-size: var(--sl-text-lg);
      font-weight: 800;
      text-decoration: none;
      white-space: nowrap;
    }

    .docs-site-title__mark {
      display: grid;
      width: 2rem;
      height: 2rem;
      flex: 0 0 auto;
      place-items: center;
      border: 1px solid rgba(139, 92, 246, 0.44);
      background: rgba(124, 58, 237, 0.1);
    }

    .docs-site-title__mark img {
      width: 1.1rem;
      height: 1.1rem;
    }
  }
</style>
