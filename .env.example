# Vessel Daemon
PORT=8080
VESSEL_DATA_DIR=./data
VESSEL_TLS_EMAIL=admin@example.com
VESSEL_HOST_IP=
VESSEL_STATIC_DIR=./dist
VESSEL_JWT_SECRET=change-this-to-a-secure-random-secret-in-prod

# Dashboard
VITE_APP_TITLE=Vessel
