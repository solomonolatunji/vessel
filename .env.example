# Codedock Environment Configuration

# Core
PORT=8080
HOST=0.0.0.0
CODEDOCK_DATA_DIR=./data
CODEDOCK_HOST_IP=

# Security (required)
CODEDOCK_JWT_SECRET=change-this-to-a-secure-random-secret-in-prod
CODEDOCK_REFRESH_SECRET=change-this-to-another-secure-random-secret
CODEDOCK_TLS_EMAIL=admin@example.com

# Docker
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Traefik Proxy Ports
# Uncomment and change if ports 80/443/8080 are already in use
# CODEDOCK_TRAEFIK_HTTP_PORT=80
# CODEDOCK_TRAEFIK_HTTPS_PORT=443
# CODEDOCK_TRAEFIK_API_PORT=8080

# Docker Images (pin specific versions)
# CODEDOCK_TRAEFIK_IMAGE=traefik:v3.0
# CODEDOCK_MINIO_IMAGE=minio/minio:latest
# CODEDOCK_PACK_IMAGE=buildpacksio/pack:latest
# CODEDOCK_BUILDER_IMAGE=paketobuildpacks/builder:base
# CODEDOCK_NIXPACKS_IMAGE=ghcr.io/railwayapp/nixpacks:latest

# Docker Deployments
CODEDOCK_RUNTIME_NETWORK=codedock-network
DEPLOY_HOST_PORT_START=4100
DEPLOY_HOST_PORT_END=4999
BUILDKIT_HOST=
DEPLOY_DRY_RUN=false

# Resource Defaults
# CODEDOCK_DEFAULT_APP_PORT=3000
# CODEDOCK_DEFAULT_MEMORY_MB=512
# CODEDOCK_DEFAULT_CPU=0.5
# CODEDOCK_DEFAULT_DB_MEMORY_MB=1024
# CODEDOCK_DEFAULT_DB_CPU=1.0

# Domains
# CODEDOCK_WILDCARD_DOMAIN=*.example.com
# CODEDOCK_MAGIC_DOMAIN=codedock.app

# Engine / Build
# CODEDOCK_MAX_CONCURRENT_BUILDS=2
# CODEDOCK_DEPLOYMENT_TIMEOUT=10m

# Dashboard (required for notifications)
CODEDOCK_DASHBOARD_URL=http://localhost:3000
CODEDOCK_STATIC_DIR=
VITE_APP_TITLE=Codedock

# Updates
CODEDOCK_UPDATE_URL=https://api.github.com/repos/solomonolatunji/codedock/releases/latest
CODEDOCK_DOWNLOAD_URL=https://github.com/solomonolatunji/codedock/releases

# Optional Integrations
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=http://localhost:8080/api/oauth/vercel/callback

# PostHog Telemetry (Optional)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
