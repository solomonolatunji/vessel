# Vessl Environment Configuration

# Core
PORT=8080
HOST=0.0.0.0
VESSL_DATA_DIR=./data
VESSL_HOST_IP=

# Security (required)
VESSL_JWT_SECRET=change-this-to-a-secure-random-secret-in-prod
VESSL_TLS_EMAIL=admin@example.com

# Docker
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Traefik Proxy Ports
# Uncomment and change if ports 80/443/8080 are already in use
# VESSL_TRAEFIK_HTTP_PORT=80
# VESSL_TRAEFIK_HTTPS_PORT=443
# VESSL_TRAEFIK_API_PORT=8080

# Docker Images (pin specific versions)
# VESSL_TRAEFIK_IMAGE=traefik:v3.0
# VESSL_MINIO_IMAGE=minio/minio:latest
# VESSL_PACK_IMAGE=buildpacksio/pack:latest
# VESSL_BUILDER_IMAGE=paketobuildpacks/builder:base
# VESSL_NIXPACKS_IMAGE=ghcr.io/railwayapp/nixpacks:latest

# Docker Deployments
VESSL_RUNTIME_NETWORK=vessl-network
DEPLOY_HOST_PORT_START=4100
DEPLOY_HOST_PORT_END=4999
BUILDKIT_HOST=
DEPLOY_DRY_RUN=false

# Resource Defaults
# VESSL_DEFAULT_APP_PORT=3000
# VESSL_DEFAULT_MEMORY_MB=512
# VESSL_DEFAULT_CPU=0.5
# VESSL_DEFAULT_DB_MEMORY_MB=1024
# VESSL_DEFAULT_DB_CPU=1.0

# Dashboard (required for notifications)
VESSL_DASHBOARD_URL=http://localhost:3000
VESSL_STATIC_DIR=
VITE_APP_TITLE=Vessl

# Updates
VESSL_UPDATE_URL=https://api.github.com/repos/solomonolatunji/vessl/releases/latest
VESSL_DOWNLOAD_URL=https://github.com/solomonolatunji/vessl/releases

# Optional Integrations
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=http://localhost:8080/api/oauth/vercel/callback

# PostHog Telemetry (Optional)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
