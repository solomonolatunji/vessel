<!DOCTYPE html>
<html lang="en">

<head>
  <style>
    body {
      font-family: sans-serif;
      line-height: 1.5;
      color: #333;
    }

    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }

    .header {
      font-weight: bold;
      font-size: 18px;
      margin-bottom: 10px;
    }

    .btn {
      display: inline-block;
      padding: 10px 15px;
      background-color: #007bff;
      color: #fff;
      text-decoration: none;
      border-radius: 4px;
      margin-top: 15px;
    }
  </style>
</head>

<body>
  <div class="container">
    {{if .Name}}<p>Hi {{.Name}},</p>{{end}}
    <div class="header">{{.Title}}</div>
    <p>{{.Message}}</p>
    <p><a class="btn" href="{{.URL}}">View in Dashboard</a></p>
  </div>
</body>

</html>
