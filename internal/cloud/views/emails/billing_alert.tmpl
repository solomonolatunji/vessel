<!DOCTYPE html>
<html lang="en">
<head><style>body{font-family:sans-serif;line-height:1.6;color:#333}.container{max-width:600px;margin:0 auto;padding:24px}.btn{display:inline-block;padding:10px 20px;background:#dc2626;color:#fff;text-decoration:none;border-radius:6px;margin-top:16px}</style></head>
<body><div class="container">
  <h2>Payment Failed</h2>
  <p>Your recent payment of ${{printf "%.2f" .Amount}} could not be processed. Please update your payment method to avoid service interruption.</p>
  <a class="btn" href="{{.BillingURL}}">Update Payment Method</a>
</div></body>
</html>
