<!DOCTYPE html>
<html lang="en">
<head>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      margin: 0;
      padding: 0;
      background-color: #f9fafb;
    }
    .container {
      max-width: 600px;
      margin: 40px auto;
      padding: 30px;
      background-color: #ffffff;
      border-radius: 8px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    }
    .header {
      font-size: 24px;
      font-weight: bold;
      color: #111827;
      margin-bottom: 20px;
      text-align: center;
    }
    .text {
      font-size: 16px;
      color: #4b5563;
      margin-bottom: 24px;
    }
    .otp-code {
      font-size: 32px;
      font-weight: bold;
      color: #0f172a;
      letter-spacing: 4px;
      text-align: center;
      margin: 30px 0;
      padding: 20px;
      background-color: #f1f5f9;
      border-radius: 8px;
    }
    .footer {
      margin-top: 40px;
      font-size: 14px;
      color: #6b7280;
      text-align: center;
      border-top: 1px solid #e5e7eb;
      padding-top: 20px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">Verify Your Email Address</div>
    <p class="text">We received a request to update the email address for your account. Please use the verification code below to confirm this change.</p>
    
    <div class="otp-code">{{.OTP}}</div>
    
    <p class="text">If you didn't request this change, you can safely ignore this email and your account email will remain unchanged.</p>
    
    <div class="footer">
      <p>This code will expire in 15 minutes.</p>
    </div>
  </div>
</body>
</html>
