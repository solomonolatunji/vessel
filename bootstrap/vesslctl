#!/usr/bin/env bash
# Vessl Control - CLI admin tool for Docker-based installations
# Usage: vesslctl <command> [args]
set -eo pipefail

VESSL_DIR=${VESSL_DIR:-/vessl}
CONTAINER_NAME="vessl-control-plane"
BOLD="\033[1m"
DIM="\033[2m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RED="\033[0;31m"
NC="\033[0m"

if [ ! -f "$VESSL_DIR/docker-compose.yml" ] && [ ! -f "./docker-compose.yml" ]; then
  echo -e "${RED}❌ No Vessl installation found.${NC} Expected docker-compose.yml in $VESSL_DIR or current directory."
  exit 1
fi

if [ ! -f "$VESSL_DIR/docker-compose.yml" ]; then
  VESSL_DIR="."
fi

exec_in_container() {
  docker compose -f "$VESSL_DIR/docker-compose.yml" exec -T "$CONTAINER_NAME" vessld "$@"
}

container_running() {
  docker ps --filter name="$CONTAINER_NAME" --format '{{.Status}}' 2>/dev/null | grep -q .
}

show_help() {
  echo -e "${BOLD}Vessl Control (vesslctl)${NC} — CLI admin tools for Vessl"
  echo ""
  echo -e "${BOLD}Usage:${NC} vesslctl <command> [args]"
  echo ""
  echo -e "${BOLD}Commands:${NC}"
  echo "  setup                    Run interactive setup wizard (create admin)"
  echo "  reset-password           Reset admin password"
  echo "  config                   View current configuration"
  echo "  config <key>=<val>       Update a config value"
  echo "  status                   Show daemon health, version, containers"
  echo "  restart                  Restart the Vessl daemon"
  echo "  logs                    Tail daemon logs"
  echo "  update [version]         Upgrade to latest or specific version"
  echo "  downgrade <version>      Downgrade to a specific version"
  echo "  backup                   Create a manual database backup"
  echo "  version                  Show Vessl version"
  echo "  help                     Show this help message"
  echo ""
  echo -e "${BOLD}App & Database Management:${NC}"
  echo "  deploy <git-url>    Deploy an app from a Git URL"
  echo "  apps:list           List all apps"
  echo "  apps:show <id>      Show app details"
  echo "  apps:create <name>  Create an app"
  echo "  apps:destroy <id>   Delete an app"
  echo "  db:list             List all databases"
  echo "  db:show <id>        Show database details"
  echo "  db:create <n> <e>   Create a database (name + engine)"
  echo "  db:destroy <id>     Delete a database"
  echo ""
  echo -e "${BOLD}Examples:${NC}"
  echo "  vesslctl setup"
  echo "  vesslctl reset-password"
  echo "  vesslctl config site-name=MyVessl"
  echo "  vesslctl status"
  echo "  vesslctl deploy https://github.com/user/app.git"
  echo "  vesslctl apps:list"
  echo "  vesslctl db:create my-db postgres --project <id>"
  echo "  vesslctl logs -f"
  echo "  vesslctl update v0.2.0"
  echo "  vesslctl downgrade v0.1.0"
}

case "${1:-help}" in
  setup|reset-password|config)
    exec_in_container "$@"
    ;;
  deploy|apps:*|db:*)
    exec_in_container "$@"
    ;;
  version)
    exec_in_container version
    ;;
  restart)
    echo -e "${YELLOW}⚠️  Restarting Vessl will briefly interrupt the dashboard.${NC}"
    echo -e "${YELLOW}   Running services (apps, databases) are NOT affected.${NC}"
    echo ""
    echo -n "Continue? (y/N): "
    read -r CONFIRM
    if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
      echo "Cancelled."
      exit 0
    fi
    echo ""
    echo -e "${BOLD}🔄 Restarting Vessl...${NC}"
    docker compose -f "$VESSL_DIR/docker-compose.yml" restart "$CONTAINER_NAME"
    echo -e "${GREEN}✅ Vessl restarted.${NC}"
    echo "   Run 'vesslctl status' to verify."
    ;;
  logs)
    shift
    docker compose -f "$VESSL_DIR/docker-compose.yml" logs "$@" "$CONTAINER_NAME"
    ;;
  status)
    echo -e "${BOLD}📊 Vessl Status${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━"

    # Daemon
    STATUS=$(docker ps --filter name="$CONTAINER_NAME" --format '{{.Status}}' 2>/dev/null)
    if [ -n "$STATUS" ]; then
      echo -e "  ${BOLD}Daemon:${NC}     ${GREEN}running${NC} ($STATUS)"
    else
      echo -e "  ${BOLD}Daemon:${NC}     ${RED}not running${NC}"
    fi
    VERSION=$(exec_in_container version 2>/dev/null || echo "unavailable")
    echo -e "  ${BOLD}Version:${NC}    $VERSION"
    echo -e "  ${BOLD}Data dir:${NC}   $VESSL_DIR/data"
    echo ""

    # System resources
    echo -e "${BOLD}  System:${NC}"
    TOTAL_RAM=$(free -m | awk '/^Mem:/{print $2}')
    USED_RAM=$(free -m | awk '/^Mem:/{print $3}')
    SWAP=$(free -m | awk '/^Swap:/{print $2}')
    DISK_USED=$(df -h / 2>/dev/null | awk 'NR==2{print $3}')
    DISK_TOTAL=$(df -h / 2>/dev/null | awk 'NR==2{print $2}')
    LOAD=$(uptime | awk -F'load average:' '{print $2}' | xargs)
    echo -e "    Memory:    ${USED_RAM}MB / ${TOTAL_RAM}MB"
    if [ "$SWAP" -gt 0 ]; then
      echo -e "    Swap:      ${SWAP}MB"
    fi
    echo -e "    Disk:      ${DISK_USED} / ${DISK_TOTAL}"
    echo -e "    Load:      ${LOAD}"
    echo ""

    # Active containers
    echo -e "${BOLD}  Active Containers:${NC}"
    CONTAINERS=$(docker ps --filter network=vessl-network --format '  {{.Names}} ({{.Image}}, {{.Status}})' 2>/dev/null)
    if [ -n "$CONTAINERS" ]; then
      echo "$CONTAINERS"
    else
      echo "    None"
    fi
    echo ""
    echo -e "  ${DIM}Run 'vesslctl logs -f' to follow daemon logs.${NC}"
    ;;
  update)
    TARGET_VERSION="${2:-latest}"
    echo -e "${BOLD}🛰️  Vessl Update Check${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━"

    # Get current version
    CURRENT=$(exec_in_container version 2>/dev/null | awk '{print $2}' || echo "unknown")

    if [ "$TARGET_VERSION" = "latest" ]; then
      echo -e "  Current:    ${CURRENT}"
      echo -e "  Target:     ${BOLD}latest${NC} (checking GitHub...)"
      # Try to fetch latest from GitHub
      LATEST=$(curl -fsS "https://api.github.com/repos/vesslhq/vessl/releases/latest" 2>/dev/null | grep '"tag_name"' | head -1 | cut -d'"' -f4 || echo "unknown")
      echo -e "  Available:  ${BOLD}${LATEST}${NC}"
      echo ""
      if [ "$LATEST" != "unknown" ] && [ "$LATEST" != "$CURRENT" ]; then
        echo -e "  ${GREEN}✨ Update available!${NC}"
      elif [ "$LATEST" = "$CURRENT" ]; then
        echo -e "  ${GREEN}✅ You're on the latest version.${NC}"
        echo ""
        echo -n "Reinstall anyway? (y/N): "
        read -r CONFIRM
        if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
          echo "Cancelled."
          exit 0
        fi
      fi
    else
      echo -e "  Current:    ${CURRENT}"
      echo -e "  Target:     ${BOLD}${TARGET_VERSION}${NC}"
      echo ""
    fi

    echo -e "${YELLOW}⚠️  A backup will be created before updating.${NC}"
    echo -n "Continue with update? (y/N): "
    read -r CONFIRM
    if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
      echo "Cancelled."
      exit 0
    fi

    echo ""
    echo -e "${BOLD}💾 Creating pre-update backup...${NC}"
    mkdir -p "$VESSL_DIR/data/backups"
    if container_running; then
      docker compose -f "$VESSL_DIR/docker-compose.yml" exec -T "$CONTAINER_NAME" sh -c "cp /vessl/data/vessl.db /vessl/data/backups/vessl-pre-upgrade-$(date +%Y%m%d%H%M%S).db" 2>/dev/null || true
    fi
    echo -e "${GREEN}✅ Backup saved to $VESSL_DIR/data/backups/${NC}"

    export VESSL_VERSION="${TARGET_VERSION}"
    echo -e "${BOLD}🐳 Pulling vessl:${TARGET_VERSION}...${NC}"
    docker compose -f "$VESSL_DIR/docker-compose.yml" pull
    echo -e "${BOLD}🚀 Recreating container...${NC}"
    docker compose -f "$VESSL_DIR/docker-compose.yml" up -d --force-recreate
    echo -e "${GREEN}✅ Vessl updated to ${TARGET_VERSION}.${NC}"
    echo "   Your apps and databases experienced zero downtime."
    echo "   Run 'vesslctl status' to verify."
    ;;
  downgrade)
    if [ -z "$2" ]; then
      echo -e "${RED}❌ Usage: vesslctl downgrade <version>${NC}"
      echo "   Example: vesslctl downgrade v0.1.0"
      echo ""
      echo "Available versions: https://github.com/vesslhq/vessl/releases"
      exit 1
    fi

    TARGET_VERSION="$2"
    CURRENT=$(exec_in_container version 2>/dev/null | awk '{print $2}' || echo "unknown")

    echo -e "${BOLD}⬇️  Vessl Downgrade${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "  Current:    ${CURRENT}"
    echo -e "  Target:     ${BOLD}${TARGET_VERSION}${NC}"
    echo ""
    echo -e "${RED}⚠️  WARNING: Downgrade${NC}"
    echo -e "${YELLOW}   • A database backup will be created automatically${NC}"
    echo -e "${YELLOW}   • Database schema changes may not be backward-compatible${NC}"
    echo -e "${YELLOW}   • If something breaks, restore from backup:${NC}"
    echo -e "${YELLOW}      cp $VESSL_DIR/data/backups/vessl-pre-downgrade-*.db \\${NC}"
    echo -e "${YELLOW}         $VESSL_DIR/data/vessl.db${NC}"
    echo ""

    if [ "$TARGET_VERSION" = "$CURRENT" ]; then
      echo -e "${YELLOW}⚠️  Target version matches current version. No downgrade needed.${NC}"
      exit 0
    fi

    echo -n "Type '${BOLD}downgrade${NC}' to confirm: "
    read -r CONFIRM
    if [ "$CONFIRM" != "downgrade" ]; then
      echo "Cancelled."
      exit 0
    fi

    echo ""
    echo -e "${BOLD}💾 Creating pre-downgrade backup...${NC}"
    mkdir -p "$VESSL_DIR/data/backups"
    if container_running; then
      docker compose -f "$VESSL_DIR/docker-compose.yml" exec -T "$CONTAINER_NAME" sh -c "cp /vessl/data/vessl.db /vessl/data/backups/vessl-pre-downgrade-$(date +%Y%m%d%H%M%S).db" 2>/dev/null || true
      echo -e "${GREEN}✅ Backup saved.${NC}"
    fi

    export VESSL_VERSION="${TARGET_VERSION}"
    echo -e "${BOLD}🐳 Pulling vessl:${TARGET_VERSION}...${NC}"
    docker compose -f "$VESSL_DIR/docker-compose.yml" pull
    echo -e "${BOLD}🚀 Recreating container with v${TARGET_VERSION}...${NC}"
    docker compose -f "$VESSL_DIR/docker-compose.yml" up -d --force-recreate
    echo -e "${GREEN}✅ Downgraded to ${TARGET_VERSION}.${NC}"
    echo -e "${YELLOW}⚠️  If you encounter issues, restore from backup:${NC}"
    echo "   cp $VESSL_DIR/data/backups/vessl-pre-downgrade-*.db $VESSL_DIR/data/vessl.db"
    echo "   vesslctl restart"
    ;;
  backup)
    BACKUP_FILE="$VESSL_DIR/data/backups/vessl-manual-$(date +%Y%m%d%H%M%S).db"
    mkdir -p "$VESSL_DIR/data/backups"
    echo -e "${BOLD}💾 Creating database backup...${NC}"
    if container_running; then
      docker compose -f "$VESSL_DIR/docker-compose.yml" exec -T "$CONTAINER_NAME" sh -c "cp /vessl/data/vessl.db /vessl/data/backups/tmp.db"
      docker compose cp "$CONTAINER_NAME:/vessl/data/backups/tmp.db" "$BACKUP_FILE"
      docker compose -f "$VESSL_DIR/docker-compose.yml" exec -T "$CONTAINER_NAME" sh -c "rm /vessl/data/backups/tmp.db"
      echo -e "${GREEN}✅ Database backed up to $BACKUP_FILE${NC}"
      echo "   Size: $(du -h "$BACKUP_FILE" | cut -f1)"
    else
      echo -e "${RED}❌ Vessl container is not running. Cannot access database.${NC}"
      exit 1
    fi
    ;;
  help|--help|-h)
    show_help
    ;;
  *)
    echo -e "${RED}❌ Unknown command: ${1}${NC}"
    echo ""
    show_help
    exit 1
    ;;
esac
