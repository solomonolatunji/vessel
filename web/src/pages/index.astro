---
import Layout from '../layouts/Layout.astro';

const marqueeItems = [
  'traefik.routing', 'cert.issued', 'postgres.backed-up', 'build.queued',
  'redis.live', 'logs.tailing', 'canvas.rendered', 'fleet.synced',
  'agent.tunnel.up', 'backup.scheduled',
];
const doubled = [...marqueeItems, ...marqueeItems];

const logoRows = [
  [
    { name: 'React',      icon: 'https://svgl.app/library/react_dark.svg' },
    { name: 'Next.js',    icon: 'https://svgl.app/library/nextjs_icon_dark.svg' },
    { name: 'Astro',      icon: 'https://svgl.app/library/astro-icon-dark.svg' },
    { name: 'Vite',       icon: 'https://svgl.app/library/vite.svg' },
    { name: 'Node.js',    icon: 'https://svgl.app/library/nodejs.svg' },
    { name: 'Svelte',     icon: 'https://svgl.app/library/svelte.svg' },
    { name: 'Nuxt',       icon: 'https://svgl.app/library/nuxt.svg' },
    { name: 'Bun',        icon: 'https://svgl.app/library/bun.svg' },
    { name: 'Docker',     icon: 'https://svgl.app/library/docker.svg' },
    { name: 'Laravel',    icon: 'https://svgl.app/library/laravel.svg' },
  ],
  [
    { name: 'PostgreSQL', icon: 'https://svgl.app/library/postgresql.svg' },
    { name: 'Redis',      icon: 'https://svgl.app/library/redis.svg' },
    { name: 'MongoDB',    icon: 'https://svgl.app/library/mongodb-icon-dark.svg' },
    { name: 'MySQL',      icon: 'https://svgl.app/library/mysql-icon-dark.svg' },
    { name: 'NestJS',     icon: 'https://svgl.app/library/nestjs.svg' },
    { name: 'TanStack',   icon: 'https://svgl.app/library/tanstack.svg' },
    { name: 'Vitest',     icon: 'https://svgl.app/library/vitest.svg' },
    { name: 'Hono',       icon: 'https://svgl.app/library/hono.svg' },
    { name: 'LangChain',  icon: 'https://svgl.app/library/langchain-logo.svg' },
    { name: 'Prisma',     icon: 'https://svgl.app/library/prisma-dark.svg' },
  ],
  [
    { name: 'Python',     icon: 'https://svgl.app/library/python.svg' },
    { name: 'Go',         icon: 'https://svgl.app/library/golang_dark.svg' },
    { name: 'TypeScript', icon: 'https://svgl.app/library/typescript.svg' },
    { name: 'Rust',       icon: 'https://svgl.app/library/rust.svg' },
    { name: 'Django',     icon: 'https://svgl.app/library/django.svg' },
    { name: 'Rails',      icon: 'https://svgl.app/library/rails.svg' },
    { name: 'Tailwind',   icon: 'https://svgl.app/library/tailwindcss.svg' },
    { name: 'Supabase',   icon: 'https://svgl.app/library/supabase.svg' },
    { name: 'Drizzle',    icon: 'https://svgl.app/library/drizzle-orm_dark.svg' },
    { name: 'ClickHouse', icon: 'https://svgl.app/library/clickhouse.svg' },
  ],
];

const features = [
  {
    icon: `<path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/>`,
    title: 'Canvas View',
    desc: "See your entire environment at a glance — apps, databases, and their connections laid out as a live topology map, not a flat list.",
  },
  {
    icon: `<rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`,
    title: 'Traefik-backed Routing',
    desc: 'Vessl spins up and manages Traefik automatically — zero-config load balancing, path routing, and automatic SSL for every service you deploy.',
  },
  {
    icon: `<path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4 22-7z"/>`,
    title: 'Git-native Deployments',
    desc: 'Connect GitHub, GitLab, or Gitea. Push a branch, get a deployment. No YAML pipelines. No external CI required.',
  },
  {
    icon: `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>`,
    title: 'Environment Scoping',
    desc: 'Group apps and services into named environments — staging, production, preview — each with isolated variables and their own deployment flow.',
  },
  {
    icon: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>`,
    title: 'Database Snapshots',
    desc: 'Schedule automatic database backups to any S3-compatible storage. Configure retention windows and restore from any checkpoint.',
  },
  {
    icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
    title: 'AI Settings Layer',
    desc: 'Each team configures its own LLM provider — OpenAI, Anthropic, local Ollama. Vessl routes completions, never stores keys plaintext.',
  },
  {
    icon: `<path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>`,
    title: 'Usage Metering',
    desc: 'The cloud tracks container-hours, deployments, and bandwidth per team. Set thresholds, get notified, never hit an unexpected bill.',
  },
  {
    icon: `<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>`,
    title: 'Yamux Tunnel Fleet',
    desc: "Vessl Cloud connects to your daemons via an encrypted Yamux tunnel — no port-forwarding, no VPN. Your servers are never directly exposed.",
  },
  {
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
    title: 'Scoped Secret Vars',
    desc: 'Inject environment variables per-service or per-environment. Secrets encrypted at rest, never visible in logs or build output.',
  },
  {
    icon: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
    title: 'Cron Jobs',
    desc: 'Define recurring jobs alongside your services — same project, same env vars, same log stream. No separate scheduler needed.',
  },
  {
    icon: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 2.68h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/>`,
    title: 'Notification Channels',
    desc: 'Route events — build failure, cert expiry, usage spikes — to email, webhook, or Discord. Configurable per project.',
  },
  {
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    title: 'Team Workspaces',
    desc: 'Invite members, assign roles, and isolate projects per team. The Cloud dashboard enforces plan limits so billing stays predictable.',
  },
];
---

<Layout
  title="Vessl — Ship fast, own your infrastructure"
  description="Vessl is a sub-30MB daemon that turns any Linux server into a full deployment platform — apps, databases, backups, domains, and a fleet control plane."
>

  <!-- ===================== HERO ===================== -->
  <section class="relative isolate min-h-[calc(100svh-64px)] overflow-hidden">
    <!-- Subtle dot grid -->
    <div class="pointer-events-none absolute inset-0 -z-10 [background-image:linear-gradient(rgba(255,255,255,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.025)_1px,transparent_1px)] [background-size:60px_60px]" aria-hidden="true"></div>
    <!-- Purple bleed top-left -->
    <div class="pointer-events-none absolute -top-32 -left-48 -z-10 w-[700px] h-[500px] rounded-full [background:radial-gradient(ellipse_at_center,rgba(124,58,237,0.13)_0%,transparent_65%)]" aria-hidden="true"></div>
    <!-- Faint right glow -->
    <div class="pointer-events-none absolute top-1/3 right-0 -z-10 w-[400px] h-[400px] [background:radial-gradient(ellipse_at_right,rgba(59,130,246,0.06)_0%,transparent_70%)]" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-7xl px-6 grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_460px] items-center gap-14 py-20 lg:py-28">

      <!-- Left: Copy -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-xs text-[var(--color-muted-foreground)] mb-6 font-medium">
          <span class="size-1.5 rounded-full bg-[var(--color-primary)] animate-pulse"></span>
          v0.5 — open source &amp; MIT licensed
        </div>

        <h1 class="text-[clamp(2.6rem,6vw,4.8rem)] font-extrabold tracking-tight leading-[0.94] text-[var(--color-foreground)]">
          Ship fast,<br/>
          <span class="text-[var(--color-primary)]">own</span> your<br/>
          infrastructure.
        </h1>

        <p class="mt-6 text-[var(--color-muted-foreground)] text-base md:text-lg leading-relaxed max-w-[520px]">
          A sub-30MB daemon that turns any Linux server into a full deployment platform.
          Apps, databases, domains, backups, and a Traefik-powered proxy — all managed from one place.
        </p>
        <p class="mt-2 text-sm text-[var(--color-muted-foreground)]">
          Free forever, backed by <a href="/philosophy" class="text-[var(--color-foreground)] underline decoration-[var(--color-primary)]/50 underline-offset-2 hover:text-[var(--color-primary)] transition-colors">our philosophy</a>.
        </p>

        <!-- Two hero CTA buttons -->
        <div class="mt-10 flex flex-col sm:flex-row gap-5">
          <div class="flex flex-col items-center">
            <a href="https://app.vessl.dev" class="flex items-center justify-center gap-2.5 px-10 py-4 rounded-lg font-semibold text-sm bg-[var(--color-surface)] hover:bg-[var(--color-border)] border border-[var(--color-border)] text-[var(--color-foreground)] transition-colors w-48">
              <svg class="size-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
              Cloud
            </a>
            <p class="text-[var(--color-primary)] text-xs font-bold mt-2">
              1,200+ <span class="text-[var(--color-muted-foreground)] font-normal">servers online</span>
            </p>
          </div>

          <div class="flex flex-col items-center">
            <a href="https://docs.vessl.dev/self-host" target="_blank" class="flex items-center justify-center gap-2.5 px-10 py-4 rounded-lg font-semibold text-sm bg-[var(--color-surface)] hover:bg-[var(--color-border)] border border-[var(--color-border)] text-[var(--color-foreground)] transition-colors w-48">
              <svg class="size-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
              Self-hosted
            </a>
            <p class="text-[var(--color-primary)] text-xs font-bold mt-2">
              &lt;30MB <span class="text-[var(--color-muted-foreground)] font-normal">single binary</span>
            </p>
          </div>
        </div>
      </div>

      <!-- Right: Terminal panel -->
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden shadow-[0_0_60px_rgba(124,58,237,0.08)] font-mono text-xs">
        <!-- Bar -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-[var(--color-border)] bg-[var(--color-background)]">
          <span class="text-[var(--color-muted-foreground)] text-[10px] font-bold uppercase tracking-widest">vessl daemon</span>
          <span class="flex items-center gap-1.5 text-green-400 text-[10px] font-semibold">
            <span class="size-1.5 rounded-full bg-green-400 animate-pulse"></span>
            CONNECTED
          </span>
        </div>

        <!-- Install command -->
        <div class="flex items-center gap-2 border-b border-[var(--color-primary)]/20 bg-[#0d0d14] px-4 py-3.5">
          <span class="text-[var(--color-primary)] font-bold shrink-0">&gt;</span>
          <code class="flex-1 text-[var(--color-foreground)] text-[0.73rem] truncate">curl -fsSL https://get.vessl.dev | sh</code>
          <button id="copy-btn" aria-label="Copy install command" class="shrink-0 p-1.5 rounded text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-border)] transition-colors">
            <svg id="copy-icon" class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </button>
        </div>

        <!-- Server info grid -->
        <div class="px-4 py-4 space-y-2.5 border-b border-[var(--color-border)]">
          {[
            { k: 'HOST',     v: 'prod-eu-1.acme.com' },
            { k: 'AGENT',    v: 'v0.5.1' },
            { k: 'PROXY',    v: 'traefik v3.1' },
            { k: 'NETWORK',  v: 'vessl-network' },
            { k: 'TUNNEL',   v: 'yamux / active', accent: true },
          ].map(r => (
            <div class="flex items-center gap-3 text-[0.71rem]">
              <span class="text-[var(--color-muted-foreground)] w-20 shrink-0">{r.k}</span>
              <span class={r.accent ? 'text-[var(--color-primary)] font-semibold' : 'text-[var(--color-foreground)]'}>{r.v}</span>
            </div>
          ))}
        </div>

        <!-- Capabilities -->
        <div class="px-4 py-4">
          <div class="text-[9px] font-bold tracking-widest uppercase text-[var(--color-muted-foreground)] mb-3">Capabilities on this node</div>
          <div class="grid grid-cols-2 gap-y-2 gap-x-4">
            {['apps', 'databases', 'cron-jobs', 'backups → S3', 'domains + SSL', 'env secrets', 'canvas view', 'log tailing'].map(cap => (
              <div class="flex items-center gap-2 text-[0.68rem] text-[var(--color-muted-foreground)]">
                <span class="size-1.5 rounded-full bg-[var(--color-primary)]/70 shrink-0"></span>
                {cap}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Marquee ticker at bottom of hero -->
    <div class="absolute inset-x-0 bottom-0 z-10 overflow-hidden border-t border-[var(--color-border)] bg-[var(--color-background)]/95 py-3 select-none" aria-hidden="true">
      <div class="flex w-max gap-10 pr-10 [animation:marquee_52s_linear_infinite]">
        {doubled.map(item => (
          <span class="shrink-0 font-mono text-[0.68rem] text-[var(--color-muted-foreground)]">
            {item}<span class="ml-10 opacity-20">—</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== STACK CAROUSEL ===================== -->
  <section class="relative overflow-hidden border-t border-[var(--color-border)] py-24">
    <!-- Very subtle radial from top -->
    <div class="pointer-events-none absolute inset-x-0 top-0 h-56 [background:radial-gradient(ellipse_55%_50%_at_50%_0%,rgba(124,58,237,0.07),transparent)]" aria-hidden="true"></div>

    <div class="mx-auto max-w-7xl px-6 mb-12">
      <h2 class="text-[clamp(1.8rem,4vw,3.5rem)] font-extrabold leading-tight text-[var(--color-foreground)]">
        Runs whatever<br/>your team ships<span class="text-[var(--color-primary)]">.</span>
      </h2>
      <p class="mt-3 text-[var(--color-muted-foreground)] text-sm max-w-md">
        If it has a Dockerfile — or even if it doesn't — Vessl can build and run it on your server.
      </p>
    </div>

    <!-- 3 rows of logos, contained width, alternating direction -->
    <div class="grid gap-4">
      {logoRows.map((logos, i) => (
        <div class="logo-marquee overflow-hidden py-3">
          <div class={`logo-track flex w-max gap-8 pr-8 ${i % 2 === 1 ? 'reverse' : ''}`}>
            {[...logos, ...logos, ...logos].map(logo => (
              <div class="flex h-16 w-20 items-center justify-center shrink-0">
                <img
                  class="h-10 w-10 object-contain opacity-50 hover:opacity-90 transition-opacity duration-200"
                  src={logo.icon}
                  alt={`${logo.name} logo`}
                  loading="lazy"
                  width="40"
                  height="40"
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===================== FEATURES ===================== -->
  <section id="features" class="border-t border-[var(--color-border)] py-24 scroll-mt-20">
    <div class="mx-auto max-w-7xl px-6">
      <h2 class="text-[clamp(1.8rem,4vw,3.5rem)] font-extrabold text-[var(--color-foreground)] mb-4">
        Everything on your server<span class="text-[var(--color-primary)]">.</span>
      </h2>
      <p class="text-[var(--color-muted-foreground)] text-sm mb-16 max-w-xl">
        Vessl isn't a wrapper — it's a daemon with real opinions: Traefik for routing, Docker for isolation, S3 for backups, Yamux for the fleet tunnel.
      </p>
      <dl class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-10">
        {features.map(f => (
          <div class="flex flex-col">
            <dt class="flex items-center gap-3 font-semibold text-sm text-[var(--color-foreground)] mb-2">
              <span class="size-8 rounded-lg bg-[var(--color-primary)]/10 border border-[var(--color-primary)]/20 flex items-center justify-center shrink-0">
                <svg class="size-4 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" set:html={f.icon}/>
              </span>
              {f.title}
            </dt>
            <dd class="text-sm text-[var(--color-muted-foreground)] leading-relaxed pl-11">{f.desc}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

</Layout>

<script>
  const btn = document.getElementById('copy-btn');
  const icon = document.getElementById('copy-icon');
  btn?.addEventListener('click', () => {
    navigator.clipboard.writeText('curl -fsSL https://get.vessl.dev | sh');
    if (icon) icon.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
    setTimeout(() => {
      if (icon) icon.innerHTML = '<rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>';
    }, 2000);
  });
</script>

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes logo-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }
  .logo-track {
    animation: logo-marquee 50s linear infinite;
  }
  .logo-track.reverse {
    animation-direction: reverse;
  }
  .logo-marquee:hover .logo-track {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .logo-track { animation: none; }
  }
</style>
