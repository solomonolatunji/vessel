---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Vessl — Self-hosting with superpowers" description="Deploy apps, databases & services to your own server. Open-source alternative to Heroku, Vercel, and Railway.">

  <!-- Hero -->
  <section class="relative pt-24 pb-16 text-center px-4 overflow-hidden">
    <!-- Grid bg -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(124,58,237,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(124,58,237,0.03)_1px,transparent_1px)] bg-[size:48px_48px] [mask-image:radial-gradient(ellipse_80%_60%_at_50%_0%,black,transparent)]"></div>

    <!-- Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-primary)]/20 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-4xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--color-primary)]/30 bg-[var(--color-primary)]/10 text-[var(--color-primary)] text-xs font-medium mb-6">
        <span class="size-1.5 rounded-full bg-[var(--color-primary)] animate-pulse"></span>
        Open-source & self-hostable
      </div>

      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-[var(--color-foreground)] leading-[1.05] mb-6">
        Self-hosting<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)]">with superpowers.</span>
      </h1>

      <p class="text-lg md:text-xl text-[var(--color-muted-foreground)] max-w-2xl mx-auto mb-10 leading-relaxed">
        Deploy apps, databases, and services to <em>your</em> server in seconds.
        Git-push deploys, real-time terminal, automatic SSL — all in a single <span class="text-[var(--color-foreground)] font-semibold">&lt;30MB binary</span>.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://app.vessl.dev" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-white font-semibold text-sm transition-all duration-200 shadow-lg shadow-[var(--color-primary)]/25 hover:shadow-[var(--color-primary)]/40 hover:-translate-y-0.5">
          Start for free
          <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="https://docs.vessl.dev" target="_blank" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-[var(--color-border)] text-[var(--color-foreground)] hover:bg-[var(--color-surface)] font-semibold text-sm transition-all duration-200">
          <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Read the docs
        </a>
      </div>

      <!-- Stats row -->
      <div class="mt-14 flex flex-wrap justify-center gap-8 text-center">
        {[
          { label: 'Binary size', value: '<30MB' },
          { label: 'One-click services', value: '80+' },
          { label: 'License', value: 'MIT' },
        ].map(stat => (
          <div>
            <div class="text-3xl font-black text-[var(--color-primary)]">{stat.value}</div>
            <div class="text-xs text-[var(--color-muted-foreground)] mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Terminal preview -->
  <section class="max-w-3xl mx-auto px-4 mb-20">
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden shadow-2xl">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-[var(--color-border)]">
        <span class="size-3 rounded-full bg-red-500/80"></span>
        <span class="size-3 rounded-full bg-yellow-500/80"></span>
        <span class="size-3 rounded-full bg-green-500/80"></span>
        <span class="ml-4 text-xs text-[var(--color-muted-foreground)] font-mono">terminal</span>
      </div>
      <pre class="p-6 text-sm font-mono overflow-x-auto leading-7 text-[var(--color-foreground)]">
<span class="text-[var(--color-muted-foreground)]">$</span> <span class="text-[var(--color-primary)]">curl</span> -sSL https://get.vessl.dev | sh

<span class="text-green-400">✓</span> Vessl daemon installed  <span class="text-[var(--color-muted-foreground)]">(22MB)</span>
<span class="text-green-400">✓</span> Docker detected
<span class="text-green-400">✓</span> Traefik reverse proxy configured

<span class="text-[var(--color-muted-foreground)]">$</span> <span class="text-[var(--color-primary)]">vessld</span> --token=<span class="text-yellow-400">tk_live_xxxx</span>

<span class="text-[var(--color-muted-foreground)]">→</span> Agent connected to Vessl Cloud
<span class="text-[var(--color-muted-foreground)]">→</span> Listening on <span class="text-[var(--color-secondary)]">wss://cloud.vessl.dev/agent/connect</span>
<span class="text-green-400">✓</span> Fleet handshake complete. Ready to deploy.</pre>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="max-w-6xl mx-auto px-4 py-16 scroll-mt-20">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-foreground)]">Everything you need.<br/><span class="text-[var(--color-muted-foreground)] font-normal text-2xl">Nothing you don't.</span></h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        {
          icon: `<path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/>`,
          title: 'Git-push deploys',
          desc: 'Push to GitHub, GitLab, or Gitea and Vessl automatically builds, deploys, and serves your app.',
        },
        {
          icon: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>`,
          title: 'Databases in one click',
          desc: 'Postgres, MySQL, Redis, MongoDB and more — deployed and managed inside Docker on your own server.',
        },
        {
          icon: `<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
          title: 'Real-time terminal',
          desc: 'SSH directly into any running container from your browser. No client setup needed.',
        },
        {
          icon: `<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
          title: 'Automatic SSL',
          desc: "Let's Encrypt certificates provisioned and renewed automatically for all your custom domains.",
        },
        {
          icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
          title: 'Usage metering',
          desc: 'Track container hours, deployments, and bandwidth. Get notified before you hit plan limits.',
        },
        {
          icon: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`,
          title: 'Fleet management',
          desc: 'Deploy to hundreds of servers simultaneously from a single Vessl Cloud dashboard.',
        },
        {
          icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
          title: 'Encrypted secrets',
          desc: 'Environment variables are encrypted at rest in your local vault. Never stored in plain text.',
        },
        {
          icon: `<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><line x1="6" y1="9" x2="6" y2="21"/>`,
          title: 'Pull request previews',
          desc: 'Every PR gets its own live preview environment. Merge with confidence.',
        },
        {
          icon: `<path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>`,
          title: 'MCP-powered AI',
          desc: 'Built-in Model Context Protocol server lets your AI tools read and manage deployments natively.',
        },
      ].map(f => (
        <div class="group p-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-primary)]/40 hover:bg-[var(--color-primary)]/5 transition-all duration-300">
          <div class="size-10 rounded-xl bg-[var(--color-primary)]/10 flex items-center justify-center mb-4 group-hover:bg-[var(--color-primary)]/20 transition-colors">
            <svg class="size-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" set:html={f.icon}/>
          </div>
          <h3 class="font-bold text-[var(--color-foreground)] mb-2">{f.title}</h3>
          <p class="text-sm text-[var(--color-muted-foreground)] leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Self-host vs Cloud comparison -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-[var(--color-foreground)] mb-3">Your infra or ours.</h2>
      <p class="text-[var(--color-muted-foreground)]">Vessl works two ways. You choose.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Self-host -->
      <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-8">
        <div class="size-10 rounded-xl bg-green-500/10 flex items-center justify-center mb-5">
          <svg class="size-5 text-green-400" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <h3 class="text-xl font-bold text-[var(--color-foreground)] mb-2">Self-hosted</h3>
        <p class="text-sm text-[var(--color-muted-foreground)] mb-6 leading-relaxed">
          Run the <code class="text-[var(--color-foreground)] bg-[var(--color-background)] px-1 py-0.5 rounded text-xs">vessl</code> daemon on any Linux server. Full control. Data never leaves your machine.
        </p>
        <ul class="space-y-2 text-sm text-[var(--color-muted-foreground)]">
          {['Free forever', 'Any VPS / bare-metal', 'Local vault encryption', 'MIT licensed source'].map(i => (
            <li class="flex items-center gap-2"><span class="text-green-400">✓</span>{i}</li>
          ))}
        </ul>
        <a href="https://docs.vessl.dev/self-host" target="_blank" class="mt-6 inline-flex items-center text-sm font-semibold text-green-400 hover:text-green-300 transition-colors gap-1">
          Self-host guide <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Cloud -->
      <div class="rounded-2xl border border-[var(--color-primary)]/40 bg-gradient-to-br from-[var(--color-primary)]/10 to-transparent p-8 relative overflow-hidden">
        <div class="absolute top-4 right-4 text-xs px-2 py-1 rounded-full bg-[var(--color-primary)]/20 text-[var(--color-primary)] font-semibold border border-[var(--color-primary)]/30">Recommended</div>
        <div class="size-10 rounded-xl bg-[var(--color-primary)]/20 flex items-center justify-center mb-5">
          <svg class="size-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
        </div>
        <h3 class="text-xl font-bold text-[var(--color-foreground)] mb-2">Vessl Cloud</h3>
        <p class="text-sm text-[var(--color-muted-foreground)] mb-6 leading-relaxed">
          We manage the control plane. Your agents run on your servers, tunnelled securely back to the cloud dashboard.
        </p>
        <ul class="space-y-2 text-sm text-[var(--color-muted-foreground)]">
          {['Fleet dashboard', 'Usage metering & alerts', 'Team seats & SSO', 'Priority support'].map(i => (
            <li class="flex items-center gap-2"><span class="text-[var(--color-primary)]">✓</span>{i}</li>
          ))}
        </ul>
        <a href="https://app.vessl.dev" class="mt-6 inline-flex items-center text-sm font-semibold text-[var(--color-primary)] hover:text-[var(--color-primary-hover)] transition-colors gap-1">
          Go to Cloud <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 py-20 text-center">
    <div class="rounded-3xl border border-[var(--color-primary)]/25 bg-gradient-to-br from-[var(--color-primary)]/10 via-[var(--color-surface)] to-[var(--color-secondary)]/5 p-12 relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(124,58,237,0.12),transparent_60%)] pointer-events-none"></div>
      <h2 class="relative text-4xl font-extrabold text-[var(--color-foreground)] mb-4">Ready to own your infra?</h2>
      <p class="relative text-[var(--color-muted-foreground)] mb-8 max-w-xl mx-auto">
        Start for free in under 2 minutes. No credit card required for the self-hosted edition.
      </p>
      <div class="relative flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://app.vessl.dev" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-white font-semibold transition-all duration-200 shadow-lg shadow-[var(--color-primary)]/30 hover:-translate-y-0.5">
          Get started free
        </a>
        <a href="https://docs.vessl.dev" target="_blank" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl border border-[var(--color-border)] text-[var(--color-foreground)] hover:bg-[var(--color-surface)] font-semibold transition-all duration-200">
          Read the docs
        </a>
      </div>
    </div>
  </section>

</Layout>
