---
const serverRows = [
  { k: 'HOST',    v: 'prod-eu-1.acme.com' },
  { k: 'AGENT',   v: 'v0.5.1' },
  { k: 'PROXY',   v: 'traefik v3.1' },
  { k: 'NETWORK', v: 'vessl-network' },
  { k: 'TUNNEL',  v: 'yamux / active', accent: true },
];

const capabilities = [
  'apps', 'databases', 'cron-jobs', 'backups → S3',
  'domains + SSL', 'env secrets', 'canvas view', 'log tailing',
];
---

<section class="relative isolate overflow-hidden py-24 lg:py-32">
  <div class="relative mx-auto max-w-4xl px-6 text-center">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-xs text-[var(--color-muted-foreground)] mb-8 font-medium">
      <span class="size-1.5 rounded-full bg-[var(--color-primary)] animate-pulse"></span>
      Open source &amp; free forever
    </div>

    <!-- Heading -->
    <h1 class="text-[clamp(2rem,4vw,3.2rem)] font-extrabold tracking-tight leading-[1] text-[var(--color-foreground)] whitespace-nowrap">
      Deploy anything, own every bit<span class="text-[var(--color-primary)]">.</span>
    </h1>

    <!-- Description -->
    <p class="mt-6 text-[var(--color-muted-foreground)] text-base md:text-lg leading-relaxed mx-auto max-w-2xl">
      Vessl is a sub-30MB daemon that turns any Linux server into a full deployment platform.
      Apps, databases, domains, backups, and a Traefik-powered proxy — one binary, your servers.
    </p>

    <!-- Install command strip -->
    <div class="mt-10 mx-auto max-w-lg flex items-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 font-mono text-sm">
      <span class="text-[var(--color-primary)] font-bold shrink-0">$</span>
      <code class="flex-1 text-left text-[var(--color-foreground)] truncate text-[0.8rem]">curl -fsSL https://get.vessl.dev | sh</code>
      <button id="copy-btn" aria-label="Copy install command" class="shrink-0 p-1.5 rounded text-[var(--color-muted-foreground)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-border)] transition-colors">
        <svg id="copy-icon" class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </button>
    </div>

    <!-- CTA buttons -->
    <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-4">
      <div class="flex flex-col items-center">
        <a href="https://app.vessl.dev" class="flex items-center justify-center gap-2.5 px-10 py-3.5 rounded-lg font-semibold text-sm bg-[var(--color-surface)] hover:bg-[var(--color-border)] border border-[var(--color-border)] text-[var(--color-foreground)] transition-colors whitespace-nowrap">
          <svg class="size-4 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
          Cloud
        </a>
        <p class="text-[var(--color-primary)] text-xs font-bold mt-1.5">
          1,200+ <span class="text-[var(--color-muted-foreground)] font-normal">servers online</span>
        </p>
      </div>
      <div class="flex flex-col items-center">
        <a href="https://docs.vessl.dev/self-host" target="_blank" class="flex items-center justify-center gap-2.5 px-10 py-3.5 rounded-lg font-semibold text-sm bg-[var(--color-surface)] hover:bg-[var(--color-border)] border border-[var(--color-border)] text-[var(--color-foreground)] transition-colors whitespace-nowrap">
          <svg class="size-4 text-[var(--color-primary)]" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
          Self-hosted
        </a>
        <p class="text-[var(--color-primary)] text-xs font-bold mt-1.5">
          &lt;30MB <span class="text-[var(--color-muted-foreground)] font-normal">single binary</span>
        </p>
      </div>
    </div>

    <!-- Terminal panel -->
    <div class="mt-12 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden text-left font-mono text-xs">
      <div class="flex items-center justify-between px-4 py-3 border-b border-[var(--color-border)] bg-[var(--color-background)]">
        <span class="text-[var(--color-muted-foreground)] text-[10px] font-bold uppercase tracking-widest">vessl daemon</span>
        <span class="flex items-center gap-1.5 text-green-400 text-[10px] font-semibold">
          <span class="size-1.5 rounded-full bg-green-400 animate-pulse"></span>
          CONNECTED
        </span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-[var(--color-border)]">
        <div class="px-5 py-4 space-y-2.5">
          {serverRows.map(r => (
            <div class="flex items-center gap-3 text-[0.71rem]">
              <span class="text-[var(--color-muted-foreground)] w-20 shrink-0">{r.k}</span>
              <span class={r.accent ? 'text-[var(--color-primary)] font-semibold' : 'text-[var(--color-foreground)]'}>{r.v}</span>
            </div>
          ))}
        </div>
        <div class="px-5 py-4">
          <div class="text-[9px] font-bold tracking-widest uppercase text-[var(--color-muted-foreground)] mb-3">Capabilities on this node</div>
          <div class="grid grid-cols-2 gap-y-2 gap-x-4">
            {capabilities.map(cap => (
              <div class="flex items-center gap-2 text-[0.68rem] text-[var(--color-muted-foreground)]">
                <span class="size-1.5 rounded-full bg-[var(--color-primary)]/70 shrink-0"></span>
                {cap}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('copy-btn');
  const icon = document.getElementById('copy-icon');
  btn?.addEventListener('click', () => {
    navigator.clipboard.writeText('curl -fsSL https://get.vessl.dev | sh');
    if (icon) icon.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
    setTimeout(() => {
      if (icon) icon.innerHTML = '<rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>';
    }, 2000);
  });
</script>
