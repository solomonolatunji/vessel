---
const logoRows = [
  [
    { name: 'React',      icon: 'https://svgl.app/library/react_dark.svg' },
    { name: 'Next.js',    icon: 'https://svgl.app/library/nextjs_icon_dark.svg' },
    { name: 'Astro',      icon: 'https://svgl.app/library/astro-icon-dark.svg' },
    { name: 'Vite',       icon: 'https://svgl.app/library/vite.svg' },
    { name: 'Node.js',    icon: 'https://svgl.app/library/nodejs.svg' },
    { name: 'Svelte',     icon: 'https://svgl.app/library/svelte.svg' },
    { name: 'Nuxt',       icon: 'https://svgl.app/library/nuxt.svg' },
    { name: 'Bun',        icon: 'https://svgl.app/library/bun.svg' },
    { name: 'Docker',     icon: 'https://svgl.app/library/docker.svg' },
    { name: 'Laravel',    icon: 'https://svgl.app/library/laravel.svg' },
    { name: 'Python',     icon: 'https://svgl.app/library/python.svg' },
    { name: 'Go',         icon: 'https://svgl.app/library/golang_dark.svg' },
    { name: 'TypeScript', icon: 'https://svgl.app/library/typescript.svg' },
    { name: 'Rust',       icon: 'https://svgl.app/library/rust.svg' },
    { name: 'Tailwind',   icon: 'https://svgl.app/library/tailwindcss.svg' },
  ],
  [
    { name: 'PostgreSQL', icon: 'https://svgl.app/library/postgresql.svg' },
    { name: 'Redis',      icon: 'https://svgl.app/library/redis.svg' },
    { name: 'MongoDB',    icon: 'https://svgl.app/library/mongodb-icon-dark.svg' },
    { name: 'MySQL',      icon: 'https://svgl.app/library/mysql-icon-dark.svg' },
    { name: 'NestJS',     icon: 'https://svgl.app/library/nestjs.svg' },
    { name: 'TanStack',   icon: 'https://svgl.app/library/tanstack.svg' },
    { name: 'Vitest',     icon: 'https://svgl.app/library/vitest.svg' },
    { name: 'Hono',       icon: 'https://svgl.app/library/hono.svg' },
    { name: 'Prisma',     icon: 'https://svgl.app/library/prisma-dark.svg' },
    { name: 'Django',     icon: 'https://svgl.app/library/django.svg' },
    { name: 'Rails',      icon: 'https://svgl.app/library/rails.svg' },
    { name: 'Supabase',   icon: 'https://svgl.app/library/supabase.svg' },
    { name: 'Drizzle',    icon: 'https://svgl.app/library/drizzle-orm_dark.svg' },
    { name: 'ClickHouse', icon: 'https://svgl.app/library/clickhouse.svg' },
    { name: 'LangChain',  icon: 'https://svgl.app/library/langchain-logo.svg' },
  ],
];
---

<section class="relative overflow-hidden py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-12 text-center">
      <h2 class="text-[clamp(1.8rem,4vw,3.5rem)] font-extrabold leading-tight text-(--color-foreground)">
        Runs whatever your team ships<span class="text-(--color-primary)">.</span>
      </h2>
      <p class="mt-3 text-(--color-muted-foreground) text-sm mx-auto max-w-md">
        If it has a Dockerfile — or even if it doesn't — Vessl can build and run it on your server.
      </p>
    </div>

    <div class="grid gap-6 overflow-hidden">
      {logoRows.map((logos, i) => (
        <div class="logo-marquee overflow-hidden py-2">
          <div class={`logo-track flex w-max gap-6 pr-6 ${i % 2 === 1 ? 'reverse' : ''}`}>
            {[...logos, ...logos, ...logos].map(logo => (
              <div class="flex h-20 w-24 items-center justify-center shrink-0">
                <img
                  class="logo-img h-14 w-14 object-contain"
                  src={logo.icon}
                  alt={`${logo.name} logo`}
                  loading="lazy"
                  width="56"
                  height="56"
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes logo-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }
  .logo-track {
    animation: logo-marquee 50s linear infinite;
  }
  .logo-track.reverse {
    animation-direction: reverse;
  }
  .logo-marquee:hover .logo-track {
    animation-play-state: paused;
  }
  .logo-img {
    opacity: 0.75;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
    -ms-interpolation-mode: nearest-neighbor;
    transition: opacity 0.2s;
  }
  .logo-img:hover {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .logo-track { animation: none; }
  }
</style>
